{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/blog",
      "regex": "^/blog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog(?:/)?$"
    },
    {
      "page": "/blog/ai-in-healthcare-from-diagnostics-to-patient-centric-care",
      "regex": "^/blog/ai\\-in\\-healthcare\\-from\\-diagnostics\\-to\\-patient\\-centric\\-care(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog/ai\\-in\\-healthcare\\-from\\-diagnostics\\-to\\-patient\\-centric\\-care(?:/)?$"
    },
    {
      "page": "/company",
      "regex": "^/company(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/company(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/icon",
      "regex": "^/icon(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/icon(?:/)?$"
    },
    {
      "page": "/privacy-policy",
      "regex": "^/privacy\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy\\-policy(?:/)?$"
    },
    {
      "page": "/products/flyhigh",
      "regex": "^/products/flyhigh(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products/flyhigh(?:/)?$"
    },
    {
      "page": "/products/sleep-alert",
      "regex": "^/products/sleep\\-alert(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products/sleep\\-alert(?:/)?$"
    },
    {
      "page": "/solutions",
      "regex": "^/solutions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/solutions(?:/)?$"
    },
    {
      "page": "/terms-of-service",
      "regex": "^/terms\\-of\\-service(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terms\\-of\\-service(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}